# Twitch app credentials — used by the API to fetch channel-specific chat badges
# (custom subscriber tiers + bit badges) for the Twitch Logs viewer via Helix.
# Register an app at https://dev.twitch.tv/console/apps to get these.
# Optional: leave blank and the log view falls back to global badges + text.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Production domain Caddy serves on (docker-compose.yml).
DOMAIN=
